{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET: Launch Arlo_chat.Api (https)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-backend",
      "program": "${workspaceFolder}/backend/Arlo_chat.Api/bin/Debug/net8.0/Arlo_chat.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/backend/Arlo_chat.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7281;http://localhost:5250"
      }
    }
  ]
}
